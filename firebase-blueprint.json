{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with history and preferences",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "history": { "type": "array", "description": "Last listened song IDs" },
        "likedGenres": { "type": "array", "description": "Genres user listens to most" }
      },
      "required": ["email"]
    },
    "Song": {
      "title": "Song",
      "description": "Metadata for a track",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "artist": { "type": "string" },
        "genre": { "type": "string" },
        "duration": { "type": "number", "description": "Duration in seconds" },
        "releaseDate": { "type": "string", "format": "date" },
        "previewUrl": { "type": "string" },
        "imageUrl": { "type": "string" },
        "appleMusicId": { "type": "string" },
        "fileType": { "type": "string", "description": "e.g. audio/mpeg" }
      },
      "required": ["title", "artist", "genre", "previewUrl"]
    },
    "Playlist": {
      "title": "Playlist",
      "description": "Collection of songs",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "userId": { "type": "string" },
        "songIds": { "type": "array" },
        "imageUrl": { "type": "string" }
      },
      "required": ["name", "songIds"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Registered users"
    },
    "/songs/{songId}": {
      "schema": "Song",
      "description": "Global song list"
    },
    "/playlists/{playlistId}": {
      "schema": "Playlist",
      "description": "Public and private playlists"
    }
  }
}
